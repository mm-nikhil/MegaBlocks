{
  "backends": [
    "megablocks_moe",
    "megablocks_dmoe"
  ],
  "device": "cuda",
  "dtype": "bfloat16",
  "iters": 15,
  "memory_preflight_fraction": 0.9,
  "memory_preflight_safety_multiplier": 1.35,
  "model_shape_name": "nano_moe_jax",
  "model_shapes_config": "configs/moe_model_shapes.json",
  "phase_iters": 10,
  "phase_profile": true,
  "phase_warmup": 3,
  "plot_mode": "phase_profile",
  "seq_len": 128,
  "shape": {
    "activation": "gelu_tanh",
    "dtype": "float32",
    "expert_intermediate_size": 512,
    "expert_type": "ffn",
    "hidden_size": 128,
    "max_position_embeddings": 128,
    "notes": "This is the current exact adapter target. Nano computes all routed experts in the reference path, while MegaBlocks computes selected experts.",
    "num_experts_per_token": 2,
    "num_hidden_layers": 4,
    "num_routed_experts": 4,
    "num_shared_experts": 0,
    "router_score_function": "softmax_logits_for_probs_topk_over_logits",
    "shared_expert_intermediate_size": 0,
    "simulation_level": "exact_adapter",
    "source": "third_party/Nano-MoE-JAX/nano_moe/config.py",
    "source_verified_on": "2026-06-17"
  },
  "skip_check_output": true,
  "skip_memory_preflight": false,
  "timing_scope": "auto",
  "tokens": [
    512,
    8192,
    65536,
    130048,
    262144
  ],
  "trials": 1,
  "warmup": 3,
  "weight_source": "nano_jax_init"
}
